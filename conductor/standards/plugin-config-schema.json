{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "bl1nk Plugin Configuration",
  "description": "Schema for validating bl1nk.jsonc plugin configuration files",
  "type": "object",
  "required": ["name", "version", "description", "contextFile"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "description": "Plugin identifier (kebab-case, alphanumeric with hyphens)",
      "minLength": 1,
      "maxLength": 64
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version (major.minor.patch)"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500,
      "description": "Brief description of the plugin's purpose"
    },
    "contextFile": {
      "type": "string",
      "pattern": "^(AGENTS\\.md|AGENT\\.md|GEMINI\\.md|CONTEXT\\.md|[A-Za-z0-9_-]+\\.md)$",
      "description": "Path to the context file relative to plugin directory. Standard names: AGENTS.md, AGENT.md, GEMINI.md, CONTEXT.md, or <PLUGIN>.md"
    },
    "components": {
      "type": "object",
      "description": "Plugin component paths",
      "properties": {
        "agents": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Glob patterns for agent definition files"
        },
        "commands": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Glob patterns for command definition files"
        },
        "skills": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Glob patterns for skill definition files"
        },
        "tools": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Glob patterns for tool implementation files"
        },
        "hooks": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Glob patterns for hook configuration files"
        },
        "themes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Glob patterns for theme definition files"
        }
      },
      "additionalProperties": false
    },
    "env": {
      "type": "object",
      "description": "Environment variable definitions",
      "additionalProperties": {
        "oneOf": [
          { "type": "string" },
          { "type": "null" }
        ]
      }
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of plugin names this plugin depends on"
    },
    "metadata": {
      "type": "object",
      "description": "Additional plugin metadata",
      "properties": {
        "author": { "type": "string" },
        "license": { "type": "string" },
        "repository": { "type": "string", "format": "uri" },
        "homepage": { "type": "string", "format": "uri" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false,

  "definitions": {
    "agentFrontmatter": {
      "type": "object",
      "required": ["name", "description", "mode"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
          "description": "Agent identifier (kebab-case)"
        },
        "description": {
          "type": "string",
          "minLength": 10,
          "maxLength": 200,
          "description": "One-line description of what this agent does"
        },
        "mode": {
          "type": "string",
          "enum": ["all", "primary", "subagent"],
          "description": "Agent operating mode: 'all' (any role), 'primary' (direct interaction), 'subagent' (delegated tasks)"
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["bash", "python", "node"]
          },
          "description": "Optional tools this agent uses: bash, python, node"
        }
      },
      "additionalProperties": false
    }
  }
}
