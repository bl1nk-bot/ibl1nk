modules = ["nodejs-20", "web", "python-3.12"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PORT = "5000"
JWT_SECRET = "88aaeb9b48f28adcadf380a96d935cbb651e5db623b7fdc4ab508f1af8a0a494"

[[ports]]
